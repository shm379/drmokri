# GEMINI_API_KEY: Used server-side for image generation and TTS (and as the
# text fallback when NabuGate is not configured). No longer exposed to the client.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# --- NabuGate gateway (recommended AI backend) ---
# When NABU_GATEWAY_URL is set, ALL AI calls (text, streaming, images, TTS and
# semantic-search embeddings) route through the gateway. Leave empty to fall
# back to calling Gemini directly. See https://github.com/nabuxai/nabugate.
# Example (co-deployed in the same Docker network): http://nabugate:8080
NABU_GATEWAY_URL=""
NABU_API_KEY=""
NABU_MODEL="nabu-smart"
NABU_IMAGE_MODEL="nabu-image"
NABU_AUDIO_MODEL="nabu-voice"
NABU_EMBED_MODEL="nabu-embed"
# Per-request timeout for gateway calls in ms (image generation gets 2x). The
# answer stream is exempt after it starts, so long generations are not cut off.
NABU_TIMEOUT_MS="60000"

# ADMIN_PASSWORD: enables the in-app settings panel (gear icon) where the
# NabuGate address / API key / models can be changed at runtime and saved to the
# database. Leave empty to DISABLE the panel entirely (recommended unless you
# need it) so the gateway config can never be changed by a visitor.
ADMIN_PASSWORD=""

# Per-IP rate limit for the paid AI endpoints (analyze, image, TTS, semantic
# search), to cap cost/abuse on a public deployment. AI_RATE_LIMIT requests per
# AI_RATE_WINDOW_MS. Set AI_RATE_LIMIT=0 to disable.
AI_RATE_LIMIT="30"
AI_RATE_WINDOW_MS="60000"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Deployment (Coolify / Docker) ---
# PORT: Port the Express server listens on. Defaults to 3000.
PORT="3000"

# DATABASE_PATH: Location of the SQLite database file.
# In Docker/Coolify this points to a mounted volume (e.g. /data/mokri_assistant.db)
# so data survives redeploys. Defaults to mokri_assistant.db in the working dir.
DATABASE_PATH="mokri_assistant.db"
